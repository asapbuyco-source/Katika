# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ─── Firebase (client-side — safe to expose, baked into the frontend bundle) ───
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# ─── Backend URL (Netlify frontend needs this to reach the Socket.IO server) ───
VITE_SOCKET_URL=https://your-railway-app.up.railway.app

# ══════════════════════════════════════════════════════════════════════
# The variables below are SERVER-SIDE ONLY.
# Set them as Railway environment variables — do NOT add VITE_ prefix.
# They must never be embedded in the client bundle.
# ══════════════════════════════════════════════════════════════════════

# ─── Fapshi Payment Gateway (Railway env vars — never in .env for the client) ───
# FAPSHI_API_KEY=FAK_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# FAPSHI_USER_TOKEN=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# FAPSHI_BASE_URL=https://live.fapshi.com

# ─── CORS (Railway env var) ───
# FRONTEND_URL=https://your-netlify-site.netlify.app
