rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── HELPER FUNCTIONS ───────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    function isFullAccount() {
      return isAuth() && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    function noAdminEscalation() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin']) ||
             request.resource.data.isAdmin == resource.data.isAdmin;
    }

    function noFinancialEscalation() {
      let diff = request.resource.data.diff(resource.data);
      let noBalanceChange = !diff.affectedKeys().hasAny(['balance']) || request.resource.data.balance == resource.data.balance;
      let noPromoChange = !diff.affectedKeys().hasAny(['promoBalance']) || request.resource.data.promoBalance == resource.data.promoBalance;
      let noRefChange = !diff.affectedKeys().hasAny(['referredBy']) || request.resource.data.referredBy == resource.data.referredBy;
      return noBalanceChange && noPromoChange && noRefChange;
    }

    // ─── USERS ───────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isAuth();

      // New user profile creation: owner only.
      // Balance is locked to 100 (starter amount); cannot self-assign admin/banned.
      // noFinancialEscalation is skipped on create because resource.data is null.
      allow create: if isOwner(uid)
                    && request.resource.data.get('isAdmin', false) == false
                    && request.resource.data.get('isBanned', false) == false
                    && request.resource.data.get('balance', 100) <= 100
                    && request.resource.data.get('promoBalance', 0) == 0;

      // Profile updates: own doc only, cannot self-escalate financials or admin
      allow update: if isOwner(uid) && noAdminEscalation() && noFinancialEscalation();

      // Transactions sub-collection: owner read only; writes go through server Admin SDK
      match /transactions/{txId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }
    }

    // ─── GAMES ───────────────────────────────────────────────────────────────
    match /games/{gameId} {
      allow read: if isAuth();
      allow create: if isFullAccount();
      // Only players in the game can update it (socket/server sync)
      allow update: if isAuth() && request.auth.uid in resource.data.players;
      allow delete: if false;
    }

    // ─── CHALLENGES ──────────────────────────────────────────────────────────
    match /challenges/{challengeId} {
      allow read: if isAuth() &&
        (request.auth.uid == resource.data.get('targetId', '') ||
         request.auth.uid == resource.data.get('sender.id', ''));
      allow create: if isFullAccount();
      allow update: if isAuth() &&
        (request.auth.uid == resource.data.get('targetId', '') ||
         request.auth.uid == resource.data.get('sender.id', ''));
      allow delete: if false;
    }

    // ─── TOURNAMENTS ─────────────────────────────────────────────────────────
    // All tournament writes go through the server Admin API only — not client SDK.
    match /tournaments/{tournamentId} {
      allow read: if isAuth();
      allow write: if false;
    }

    match /tournament_matches/{matchId} {
      allow read: if isAuth();
      allow write: if false;
    }

    // ─── FINANCIAL COLLECTIONS — SERVER ADMIN SDK ONLY ───────────────────────
    // These collections must NEVER be client-writable.
    match /processed_payments/{transId} { allow read, write: if false; }
    match /processed_settlements/{settlementId} { allow read, write: if false; }
    match /processed_tournaments/{tournamentId} { allow read, write: if false; }
    match /pending_payments/{transId} { allow read, write: if false; }

    // ─── SETTINGS ────────────────────────────────────────────────────────────
    match /settings/{settingId} {
      allow read: if isAuth();
      allow write: if false;
    }

    match /game_configs/{gameId} {
      allow read: if isAuth();
      allow write: if false;
    }

    // ─── FORUM POSTS ─────────────────────────────────────────────────────────
    // userId is the authoritative field (written by sendForumMessage in firebase.ts)
    match /forum_posts/{postId} {
      allow read: if isAuth();
      allow create: if isFullAccount();
      // FIX: was checking 'authorId' which does not exist — corrected to 'userId'
      allow update: if isAuth() && request.auth.uid == resource.data.get('userId', '');
      // FIX: was 'if false' — author should be able to delete their own post
      allow delete: if isAuth() && request.auth.uid == resource.data.get('userId', '');
    }

    // ─── BUG REPORTS ─────────────────────────────────────────────────────────
    match /bug_reports/{reportId} {
      allow read: if false;
      allow create: if isAuth();
      allow update, delete: if false;
    }

    // ─── LIVE WINNERS ─────────────────────────────────────────────────────────
    // Publicly readable so the win feed works without auth
    match /live_winners/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // ─── GAME AUDIT LOGS ─────────────────────────────────────────────────────
    // Players can read their own logs to file disputes.
    match /game_logs/{roomId} {
      allow read: if isAuth() && request.auth.uid in resource.data.players;
      allow write: if false;
    }

    // ─── DISPUTES ────────────────────────────────────────────────────────────
    // Players can file disputes and read their own dispute status.
    // The filedBy field is null on the create call, so read must tolerate null on new docs.
    match /disputes/{disputeId} {
      allow create: if isFullAccount() && request.resource.data.filedBy == request.auth.uid;
      allow read: if isAuth() && (
        request.auth.uid == resource.data.filedBy ||
        resource.data.filedBy == null
      );
      allow update, delete: if false;
    }

    // ─── DAILY BONUSES — SERVER ADMIN SDK ONLY ───────────────────────────────
    match /daily_bonuses/{bonusId} {
      allow read, write: if false;
    }

    // ─── FLAGGED USERS — SERVER ADMIN SDK ONLY ───────────────────────────────
    match /flagged_users/{userId} {
      allow read, write: if false;
    }

    // ─── DENY EVERYTHING ELSE ────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
